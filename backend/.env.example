APP_NAME="Spend Sense API"
APP_VERSION="0.1.0"
ENVIRONMENT="local"

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generate for production: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY="change-me-in-development"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ───────────────────────────────────────────────────────────────────
# Local:      postgresql+psycopg://postgres:postgres@localhost:5432/spend_sense
# Production: postgresql+psycopg://user:pass@host.neon.tech/spend_sense?sslmode=require
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/spend_sense"

# ── CORS ───────────────────────────────────────────────────────────────────────
# Local development
BACKEND_CORS_ORIGINS='["http://localhost:8080", "http://localhost:5173"]'
# Production example: '["https://spend-sense.vercel.app"]'

# ── OpenAPI ────────────────────────────────────────────────────────────────────
# Set to false in production to hide Swagger UI from the public internet
OPENAPI_ENABLED=true

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Monitoring (optional) ──────────────────────────────────────────────────────
# Create a project at https://sentry.io and paste the DSN here
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── AI Insights (optional) ────────────────────────────────────────────────────
AI_PROVIDER=mock
# GEMINI_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
# CLAUDE_API_KEY=your-key-here
